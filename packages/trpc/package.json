{
	"name": "@repo/trpc",
	"type": "module",
	"private": true,
	"exports": {
		".": {
			"default": "./dist/index.js",
			"types": "./src/index.ts"
		},
		"./client": {
			"default": "./dist/client.js",
			"types": "./src/client.ts"
		},
		"./router": {
			"default": "./dist/router.js",
			"types": "./src/router.ts"
		}
	},
	"scripts": {
		"format": "prettier --write src/**/*.ts",
		"compile": "tsc",
		"typecheck": "tsc --noEmit"
	}
}
