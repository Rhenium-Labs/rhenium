generator kysely {
  provider           = "prisma-kysely"
  output             = "../src/"
  fileName           = "Schema.ts"
  enumFileName       = "Enums.ts"
  importExtension    = ".js"
  exportWrappedTypes = true
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  AutoResolved
  Pending
  Disregarded
  Accepted
  Denied
}

enum ReportStatus {
  AutoResolved
  Pending
  Disregarded
  Resolved
}

enum Detector {
  NSFW
  OCR
  TEXT
}

enum ContentFilterStatus {
  Pending
  Resolved
  False
  Deleted
}

model Guild {
  id String @id

  // JSON column to store the guild's configuration.
  config Json

  ban_requests          BanRequest[]
  highlights            Highlight[]
  message_reports       MessageReport[]
  quick_mutes           QuickMute[]
  messages              Message[]
  quick_purges          QuickPurge[]
  content_filter_alerts ContentFilterAlert[]
  content_filter_logs   ContentFilterLog[]
}

model Whitelist {
  // ID of the whitelisted guild.
  id         String   @id
  created_at DateTime @default(now())
}

model ContentFilterAlert {
  id               String              @id
  guild_id         String
  message_id       String
  channel_id       String
  alert_message_id String
  alert_channel_id String
  offender_id      String
  detectors        Detector[]          @default([])
  highest_score    Float               @default(0)
  mod_status       ContentFilterStatus @default(Pending)
  del_status       ContentFilterStatus @default(Pending)
  created_at       DateTime            @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@index([guild_id, channel_id, created_at])
  @@index([message_id])
}

model ContentFilterLog {
  id         String   @id
  guild_id   String
  alert_id   String
  content    String
  created_at DateTime @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@index([alert_id])
  @@index([created_at])
}

model BanRequest {
  id                         String  @id
  guild_id                   String
  target_id                  String
  target_muted_automatically Boolean @default(false)

  status RequestStatus @default(Pending)

  resolved_at DateTime?
  resolved_by String?

  requested_at DateTime  @default(now())
  requested_by String
  expires_at   DateTime?

  reason String

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model TemporaryBan {
  guild_id   String
  target_id  String
  expires_at DateTime

  @@unique([guild_id, target_id])
}

model MessageReport {
  id           String  @id
  guild_id     String
  message_id   String
  reference_id String?
  message_url  String
  channel_id   String
  author_id    String
  content      String?

  reported_at          DateTime
  reported_by          String
  report_reason        String
  additional_reporters String[] @default([])

  status ReportStatus @default(Pending)

  resolved_at DateTime?
  resolved_by String?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model Highlight {
  user_id         String
  guild_id        String
  patterns        String[]                  @default([])
  user_blacklist  String[]                  @default([])
  channel_scoping HighlightChannelScoping[]

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id])
}

model HighlightChannelScoping {
  user_id    String
  guild_id   String
  channel_id String
  /// Include [`0`] or Exclude [`1`]
  type       Int
  highlight  Highlight @relation(fields: [user_id, guild_id], references: [user_id, guild_id], onDelete: Cascade)

  @@id([user_id, guild_id, channel_id])
}

model QuickMute {
  user_id  String
  guild_id String
  reaction String

  duration     BigInt
  reason       String
  purge_amount Int    @default(0)

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id, reaction])
}

model QuickPurge {
  user_id      String
  guild_id     String
  reaction     String
  purge_amount Int

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id, reaction])
}

model Message {
  id           String   @id
  guild_id     String
  author_id    String
  channel_id   String
  sticker_id   String?
  reference_id String?
  created_at   DateTime
  content      String?
  attachments  String[]
  deleted      Boolean  @default(false)

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model Session {
  user_id       String   @id
  access_token  String
  refresh_token String
  expires_at    DateTime
  updated_at    DateTime @default(now())
}
