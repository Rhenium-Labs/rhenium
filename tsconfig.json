{
	"compilerOptions": {
		// Strict Type-Checking
		"strict": true,
		"alwaysStrict": true,

		// Module And Library Options
		"lib": ["ESNext"],
		"target": "ESNext",
		"rootDir": "src",
		"noEmit": true,
		"types": ["bun-types"],
		"module": "esnext",
		"moduleResolution": "bundler",

		// Source Map Options
		"sourceMap": true,
		"sourceRoot": "/",
		"inlineSources": true,

		// Advanced Options
		"skipLibCheck": true,
		"downlevelIteration": true,
		"noImplicitOverride": true,
		"allowSyntheticDefaultImports": true,

		// Decorator Options
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,

		// Additional Options
		"pretty": true,
		"removeComments": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,

		"paths": {
			"@config/*": ["./src/managers/config/*"],
			"@database/*": ["./src/managers/database/*"],
			"@utils/*": ["./src/utils/*"],
			"@cf/*": ["./src/managers/content-filtering/*"],
			"@commands/*": ["./src/managers/runtime/commands/*"],
			"@components/*": ["./src/managers/runtime/components/*"],
			"@events/*": ["./src/managers/runtime/events/*"],
			"@managers/*": ["./src/managers/*"],
			"@root/*": ["./src/*"]
		}
	},
	"include": ["./src/**/*"]
}
