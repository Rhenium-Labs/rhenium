{
	"name": "rhenium",
	"description": "Monorepo for Rhenium, an AI powered discord bot.",
	"homepage": "https://github.com/Rhenium-Labs/rhenium#readme",
	"bugs": {
		"url": "https://github.com/Rhenium-Labs/rhenium/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Rhenium-Labs/rhenium.git"
	},
	"contributors": [
		"Eddy <cobaltorum>",
		"SpiderMat <SplderMat>"
	],
	"packageManager": "bun@1.3.10",
	"workspaces": [
		"packages/*",
		"applications/*",
		"applications/dashboard/*"
	],
	"scripts": {
		"typecheck": "turbo run typecheck",
		"lint": "oxlint .",
		"lint:fix": "oxlint . --fix",
		"format": "turbo run format",
"db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "db:migrate": "prisma migrate deploy --schema=packages/database/prisma/schema.prisma"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"autoprefixer": "^10.4.24",
		"bun-types": "1.3.9",
		"postcss": "^8.5.6",
		"prettier": "3.8.1",
		"tailwindcss": "^4.2.1",
		"turbo": "2.8.10",
		"typescript": "5.9.3"
	},
	"dependencies": {
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-query-devtools": "^5.91.3",
		"@tanstack/react-router": "^1.162.6",
		"@trpc/client": "^11.10.0",
		"@trpc/react-query": "^11.10.0",
		"@trpc/server": "^11.10.0",
		"dotenv": "^17.3.1",
		"kysely": "^0.28.11",
		"kysely-postgres-js": "^3.0.0",
		"postgres": "^3.4.8",
		"prisma": "^7.4.1",
		"prisma-kysely": "^3.1.0",
		"zod": "^4.3.6",
		"zod-validation-error": "^5.0.0"
	}
}
