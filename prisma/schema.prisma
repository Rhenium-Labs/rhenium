generator client {
  provider = "prisma-client"
  output   = "../src/lib/prisma"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  AutoResolved
  Pending
  Disregarded
  Accepted
  Denied
}

enum ReportStatus {
  AutoResolved
  Pending
  Disregarded
  Resolved
}

enum Detector {
  NSFW
  OCR
  TEXT
}

enum DetectorMode {
  Lenient
  Medium
  Strict
}

enum ContentFilterVerbosity {
  Minimal
  Medium
  Verbose
}

enum ContentFilterStatus {
  Pending
  Resolved
  False
  Deleted
}

enum UserPermission {
  ReviewMessageReports
  ReviewBanRequests
  UseHighlights
  UseQuickMute
  UseQuickPurge
}

model Guild {
  id String @id

  message_report_config MessageReportConfig?
  ban_request_config    BanRequestConfig?
  content_filter_config ContentFilterConfig?
  highlight_config      HighlightConfig?
  quick_mute_config     QuickMuteConfig?
  quick_purge_config    QuickPurgeConfig?

  ban_requests          BanRequest[]
  highlights            Highlight[]
  message_reports       MessageReport[]
  quick_mutes           QuickMute[]
  messages              Message[]
  quick_purges          QuickPurge[]
  permission_scopes     PermissionScope[]
  content_filter_alerts ContentFilterAlert[]
  content_filter_logs   ContentFilterLog[]
}

model Whitelist {
  // ID of the whitelisted guild.
  id         String   @id
  created_at DateTime @default(now())
}

model MessageReportConfig {
  // ID of the guild.
  id                   String  @id
  // Whether message reporting is enabled.
  enabled              Boolean @default(false)
  webhook_url          String?
  log_webhook_url      String?
  auto_disregard_after BigInt  @default(0)

  immune_roles       String[] @default([])
  notify_roles       String[] @default([])
  blacklisted_users  String[] @default([])
  placeholder_reason String?

  enforce_member_in_guild Boolean @default(true)

  guild Guild @relation(fields: [id], references: [id], onDelete: Cascade)
}

model BanRequestConfig {
  // ID of the guild.
  id      String  @id
  // Whether ban request handling is enabled.
  enabled Boolean @default(false)

  webhook_url           String?
  log_webhook_url       String?
  decision_webhook_url  String?
  automatically_timeout Boolean @default(false)

  immune_roles String[] @default([])
  notify_roles String[] @default([])

  enforce_submission_reason Boolean @default(true)
  enforce_accept_reason     Boolean @default(true)
  enforce_deny_reason       Boolean @default(true)

  guild Guild @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ContentFilterConfig {
  // ID of the guild.
  id                 String  @id
  enabled            Boolean @default(false)
  use_native_automod Boolean @default(false)
  webhook_url        String?

  detectors     Detector[]             @default([])
  detector_mode DetectorMode           @default(Medium)
  verbosity     ContentFilterVerbosity @default(Medium)

  immune_roles String[] @default([])
  notify_roles String[] @default([])

  included_channels String[] @default([])
  excluded_channels String[] @default([])

  ocr_filter_keywords String[] @default([])
  ocr_filter_regex    String[] @default([])

  guild Guild @relation(fields: [id], references: [id], onDelete: Cascade)
}

model ContentFilterAlert {
  id               String              @id @default(cuid())
  guild_id         String
  message_id       String
  channel_id       String
  alert_message_id String
  alert_channel_id String
  offender_id      String
  detectors        Detector[]
  highest_score    Float               @default(0)
  mod_status       ContentFilterStatus @default(Pending)
  del_status       ContentFilterStatus @default(Pending)
  created_at       DateTime            @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@index([guild_id, channel_id, created_at])
  @@index([message_id])
}

model ContentFilterLog {
  id         String   @id @default(cuid())
  guild_id   String
  alert_id   String
  content    String
  created_at DateTime @default(now())

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@index([alert_id])
  @@index([created_at])
}

model BanRequest {
  id                         String  @id
  guild_id                   String
  target_id                  String
  target_muted_automatically Boolean @default(false)

  status RequestStatus @default(Pending)

  resolved_at DateTime?
  resolved_by String?

  requested_at DateTime @default(now())
  requested_by String

  duration BigInt?
  reason   String

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model TemporaryBan {
  guild_id   String
  target_id  String
  expires_at DateTime

  @@unique([guild_id, target_id])
}

model MessageReport {
  id           String  @id
  guild_id     String
  message_id   String
  reference_id String?
  message_url  String
  channel_id   String
  author_id    String
  content      String?

  reported_at   DateTime
  reported_by   String
  report_reason String

  status ReportStatus @default(Pending)

  resolved_at DateTime?
  resolved_by String?

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model HighlightConfig {
  id String @id

  enabled      Boolean @default(false)
  // Hardcoded limit of 30 highlights per user.
  max_patterns Int     @default(15)
  guild        Guild   @relation(fields: [id], references: [id], onDelete: Cascade)
}

model Highlight {
  user_id         String
  guild_id        String
  patterns        String[]
  user_blacklist  String[]
  channel_scoping HighlightChannelScoping[]

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id])
}

model HighlightChannelScoping {
  user_id    String
  guild_id   String
  channel_id String
  /// Include [`0`] or Exclude [`1`]
  type       Int
  highlight  Highlight @relation(fields: [user_id, guild_id], references: [user_id, guild_id], onDelete: Cascade)

  @@id([user_id, guild_id, channel_id])
}

model QuickMuteConfig {
  // ID of the guild.
  id String @id

  enabled            Boolean                   @default(false)
  purge_limit        Int                       @default(100)
  webhook_url        String?
  result_webhook_url String?
  channel_scoping    QuickMuteChannelScoping[]

  guild Guild @relation(fields: [id], references: [id], onDelete: Cascade)
}

model QuickMuteChannelScoping {
  guild_id          String
  channel_id        String
  /// Include [`0`] or Exclude [`1`]
  type              Int
  quick_mute_config QuickMuteConfig @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([guild_id, channel_id])
}

model QuickMute {
  user_id      String
  guild_id     String
  reaction     String
  duration     BigInt
  reason       String
  purge_amount Int    @default(0)

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id, reaction])
}

model QuickPurgeConfig {
  id String @id

  enabled            Boolean                    @default(false)
  max_limit          Int                        @default(100)
  webhook_url        String?
  result_webhook_url String?
  channel_scoping    QuickPurgeChannelScoping[]

  guild Guild @relation(fields: [id], references: [id], onDelete: Cascade)
}

model QuickPurgeChannelScoping {
  guild_id           String
  channel_id         String
  /// Include [`0`] or Exclude [`1`]
  type               Int
  quick_purge_config QuickPurgeConfig @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([guild_id, channel_id])
}

model QuickPurge {
  user_id      String
  guild_id     String
  reaction     String
  purge_amount Int

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([user_id, guild_id, reaction])
}

model Message {
  id           String   @id
  guild_id     String
  author_id    String
  channel_id   String
  sticker_id   String?
  reference_id String?
  created_at   DateTime
  content      String?
  attachments  String[]
  deleted      Boolean  @default(false)

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)
}

model PermissionScope {
  guild_id            String
  role_id             String
  allowed_permissions UserPermission[]

  guild Guild @relation(fields: [guild_id], references: [id], onDelete: Cascade)

  @@id([guild_id, role_id])
}
